# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tirely

# Auth
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:4000

# CORS
CORS_ORIGIN=http://localhost:3000

# App
APP_URL=http://localhost:3000
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
REPORT_CACHE_TTL_MS=60000
STATISTICS_CACHE_TTL_MS=60000
ERROR_REPORT_WEBHOOK_URL=

# Email
EMAIL_PROVIDER=console        # resend | console (default: console)
EMAIL_FROM="Tirely <noreply@tirely.example>"

# Resend (only when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
