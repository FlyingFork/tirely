# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tirely_dev

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
REPORT_CACHE_TTL_MS=60000
STATISTICS_CACHE_TTL_MS=60000
ERROR_REPORT_WEBHOOK_URL=

# Auth
BETTER_AUTH_SECRET=generate-a-long-random-secret-here
BETTER_AUTH_URL=http://localhost:4000

# Email — EMAIL_PROVIDER controls the adapter used at runtime
# Values: console (default, logs to stdout) | resend (sends via Resend API)
EMAIL_PROVIDER=console
# Required when EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Scheduler — cron expression for the daily usage-algorithm refresh (default: midnight UTC)
USAGE_ALGORITHM_REFRESH_CRON=0 0 * * *

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
